{
  "name": "invoice_generator",
  "version": "0.0.1",
  "type": "module",
  "description": "Generate invoices",
  "main": "index.js",
  "author": "",
  "license": "ISC",
  "scripts": {
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "test:migrate": "dotenv -e .env.test -- prisma migrate deploy",
    "dev:migrate": "dotenv -e .env.development -- prisma migrate deploy",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js -i",
    "start": "node src/index.js",
    "dev": "node src/index.js",
    "format": "prettier --write \"**/*.{js,json,md}\""
  },
  "dependencies": {
    "@azure/identity": "^4.13.1",
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/client": "^6.6.0",
    "command-line-args": "^6.0.1",
    "dotenv": "^17.3.1",
    "glob": "^13.0.6",
    "moment": "^2.30.1",
    "nodemailer": "^8.0.3",
    "pdf-merger-js": "^5.1.2",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",
    "puppeteer": "^24.40.0",
    "read-excel-file": "^7.0.2",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "overrides": {
    "esbuild": "^0.25.2"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "prettier": "^3.8.1",
    "prisma": "^6.6.0"
  }
}
